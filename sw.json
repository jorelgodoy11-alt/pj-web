self.addEventListener("install", e => {

  e.waitUntil(

    caches.open("pj-cache-v3").then(cache => {

      return cache.addAll([

        "./",
        "./index.html",
        "./pj.html",
        "./evaluaciones.html",
        "./asistencias.html",
        "./admin.html",
        "./cambiar.html"

      ]);

    })

  );

});


self.addEventListener("fetch", e => {

  e.respondWith(

    caches.match(e.request).then(res => {

      return res || fetch(e.request);

    })

  );

});
