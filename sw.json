self.addEventListener("install", e => {
  e.waitUntil(
    caches.open("pj-cache").then(cache => {
      return cache.addAll([
        "/",
        "/index.html",
        "/PJ.html",
        "/Evaluaciones.html",
        "/Asistencias.html",
        "/admin.html"
      ]);
    })
  );
});

self.addEventListener("fetch", e => {
  e.respondWith(
    caches.match(e.request).then(res => {
      return res || fetch(e.request);
    })
  );
});
